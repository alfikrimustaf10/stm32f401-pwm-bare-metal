ENTRY(Reset_Handler)

_estack = 0x20018000;

MEMORY
{
FLASH (rx) : ORIGIN = 0x08000000, LENGTH = 512K
RAM (rx) : ORIGIN = 0x20000000, LENGTH = 96K
}

SECTIONS
{
.isr_vector :
{
*(.isr_vector)
} > FLASH

.text :
{
*(.text)
*(.rodat)
} > FLASH

.data :
{
*(.data)
} > RAM AT > FLASH

.bss :
{
*(.bss)
} > RAM

}
